# docker/was/.env.example
# Copy this file to docker/was/.env and fill real secrets.
# Do NOT commit the resulting .env file.
#
# Note: PROMETHEUS_BASE_URL is intentionally NOT listed here.
# It is hardcoded in docker-compose.yml as http://prometheus:9090
# (container DNS of our prometheus service).

# Pythia DB
DB_USERNAME=pythia
DB_PASSWORD=pythia

# Pythia Mail (Gmail SMTP)
MAIL_USERNAME=changeme@example.com
MAIL_PASSWORD=changeme

# Pythia OpenAI
OPENAI_API_KEY=sk-xxxxxxxx
